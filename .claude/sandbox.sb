; Project-specific sandbox rules for drum-to-chart.
; Merged into the base claude sandbox profile at launch.

; Allow reading the RunPod SSH key for deployment
(allow file-read*
    (literal (string-append (param "HOME") "/.ssh/runpod_ed25519"))
)

; Allow modifying scan-chart
(allow file-write*
    (subpath (string-append (param "HOME") "/projects/scan-chart"))
)