# Run dependency lifecycle scripts, but only for the packages explicitly
# allowlisted in pnpm-workspace.yaml's onlyBuiltDependencies. This overrides a
# global `ignore-scripts=true` (~/.npmrc) so that `pnpm install` builds the few
# native/CLI deps that need it (better-sqlite3, sharp, @sentry/cli, supabase)
# and applies the root patch-package postinstall — while pnpm still blocks every
# other dependency's scripts. Combined with `minimumReleaseAge`, this is pnpm's
# recommended supply-chain posture (finer-grained than a blanket ignore-scripts).
ignore-scripts=false
